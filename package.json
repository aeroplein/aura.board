{
  "name": "digital-vision-board",
  "private": true,
  "version": "1.0.0",
  "description": "Student portfolio digital vision board built with Vite, vanilla JavaScript, ASP.NET Core, EF Core, and PostgreSQL.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "dotnet run",
    "build": "vite build",
    "clean": "node scripts/clean-build.mjs",
    "lint": "node scripts/lint.mjs",
    "test:professionalization": "dotnet run --project tests/ProfessionalizationChecks/ProfessionalizationChecks.csproj",
    "audit:backend": "dotnet list package --vulnerable --include-transitive",
    "audit:frontend": "npm audit --audit-level=moderate",
    "audit": "npm run audit:backend && npm run audit:frontend"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "jspdf": "^4.2.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.2",
    "tailwindcss": "^4.1.14"
  }
}
