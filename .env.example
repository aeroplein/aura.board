# GEMINI_API_KEY: Optional. Enables Gemini AI recommendations.
# Leave the placeholder value to use local fallback responses during development.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: Optional. Defaults to a current Gemini generateContent model.
GEMINI_MODEL="gemini-2.5-flash"

# GEMINI_FALLBACK_MODEL: Optional. Used when the primary Gemini model is rate-limited or under high demand.
GEMINI_FALLBACK_MODEL="gemini-2.5-flash-lite"

# UNSPLASH_ACCESS_KEY: Optional. Enables live keyword image search for generated image cards.
# Leave the placeholder value to use curated fallback images during development.
UNSPLASH_ACCESS_KEY="YOUR_UNSPLASH_ACCESS_KEY"

# APP_URL: Optional. Used to build collaborator invite links.
APP_URL="http://localhost:5000"

# Database: required for real accounts, boards, and login sessions.
# Use either DEFAULT_CONNECTION for local PostgreSQL or DATABASE_URL on hosts such as Render.
DEFAULT_CONNECTION="Host=localhost;Database=aura_board;Username=postgres;Password=postgres"
# DATABASE_URL="postgres://user:password@host:5432/aura_board"

# JWT_SECRET: Required for signed HttpOnly auth cookies.
# Use a unique value with at least 32 characters outside local development.
JWT_SECRET="fake-jwt-secret-replace-me-at-least-32-chars"

# SMTP settings: Optional. Required only for sending collaborator invitation emails.
# For Gmail, use an app password, not your normal account password.
SMTP_HOST="smtp.example.invalid"
SMTP_PORT="587"
SMTP_USE_SSL="true"
SMTP_USERNAME="fake-smtp-user@example.invalid"
SMTP_PASSWORD="fake-smtp-password-replace-me"
SMTP_FROM="fake-sender@example.invalid"
