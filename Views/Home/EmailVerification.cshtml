@{
    Layout = null;
    var state = ViewData["State"] as string ?? "error";
    var title = ViewData["Title"] as string ?? "Email verification";
    var message = ViewData["Message"] as string ?? "Please try again.";
    var isSuccess = state == "success";
    var isInfo = state == "info";
    var icon = isSuccess ? "✓" : isInfo ? "i" : "!";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#5E548E" />
    <title>@title · Aura Board</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
        :root { color-scheme: light; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
        * { box-sizing: border-box; }
        body { min-height: 100vh; margin: 0; display: grid; place-items: center; overflow: hidden; color: #332A5E; background: #f8f7ff; }
        body::before, body::after { content: ""; position: fixed; border-radius: 999px; filter: blur(1px); pointer-events: none; }
        body::before { width: 34rem; height: 34rem; left: -13rem; bottom: -15rem; background: #e4dcff; }
        body::after { width: 28rem; height: 28rem; top: -14rem; right: -8rem; background: #fde1ed; }
        main { position: relative; z-index: 1; width: min(92vw, 32rem); padding: 1.25rem; }
        .card { padding: clamp(2rem, 8vw, 3.5rem); text-align: center; background: rgba(255,255,255,.86); border: 1px solid rgba(200,182,255,.65); border-radius: 2rem; box-shadow: 0 1.5rem 4rem rgba(94,84,142,.14); backdrop-filter: blur(14px); }
        .brand { display: inline-flex; align-items: center; gap: .55rem; margin-bottom: 2.3rem; color: #5e548e; font-weight: 800; letter-spacing: -.025em; }
        .spark { display: grid; place-items: center; width: 1.75rem; height: 1.75rem; border-radius: .65rem; color: white; background: linear-gradient(135deg, #5e548e, #9f86c0); font-size: 1.1rem; }
        .status-icon { display: grid; place-items: center; width: 4.5rem; height: 4.5rem; margin: 0 auto 1.5rem; border-radius: 50%; font-weight: 800; font-size: 2.1rem; }
        .success { color: #18865b; background: #dcf8ea; box-shadow: inset 0 0 0 1px #a9eaca; }
        .info { color: #5e548e; background: #eeeaff; box-shadow: inset 0 0 0 1px #d5cbff; }
        .error { color: #b24460; background: #fff0f3; box-shadow: inset 0 0 0 1px #ffd1da; }
        h1 { margin: 0; font-size: clamp(1.55rem, 5vw, 2rem); letter-spacing: -.045em; color: #342963; }
        p { max-width: 23rem; margin: 1rem auto 2rem; color: #70688b; line-height: 1.65; font-size: .96rem; }
        a { display: inline-flex; align-items: center; justify-content: center; min-height: 2.9rem; padding: .7rem 1.25rem; border-radius: .85rem; color: white; background: #5e548e; box-shadow: 0 .5rem 1rem rgba(94,84,142,.18); font-weight: 750; text-decoration: none; transition: transform .18s ease, background .18s ease; }
        a:hover { background: #796bad; transform: translateY(-2px); }
        .hint { margin: 1.5rem 0 0; color: #9a91b1; font-size: .78rem; }
        @@media (prefers-reduced-motion: reduce) { a { transition: none; } }
    </style>
</head>
<body>
    <main>
        <section class="card" aria-labelledby="verification-title">
            <div class="brand"><span class="spark">✦</span> aura.board</div>
            <div class="status-icon @state" aria-hidden="true">@icon</div>
            <h1 id="verification-title">@title</h1>
            <p>@message</p>
            <a href="/">@(isSuccess || isInfo ? "Sign in to Aura Board" : "Go to Aura Board")</a>
            @if (isSuccess)
            {
                <p class="hint">You can close this page after signing in.</p>
            }
        </section>
    </main>
</body>
</html>
