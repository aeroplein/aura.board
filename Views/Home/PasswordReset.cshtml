@{
    Layout = null;
    var state = ViewData["State"] as string ?? string.Empty;
    var title = ViewData["Title"] as string;
    var email = ViewData["Email"] as string ?? string.Empty;
    var token = ViewData["Token"] as string ?? string.Empty;
    var isSuccess = state == "success";
    var isError = state == "error";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#5E548E" />
    <title>Password reset · Aura Board</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
        :root { color-scheme: light; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
        * { box-sizing: border-box; }
        body { min-height: 100vh; margin: 0; display: grid; place-items: center; color: #332A5E; background: #f8f7ff; }
        main { width: min(92vw, 30rem); padding: 1.25rem; }
        .card { padding: clamp(2rem, 8vw, 3rem); text-align: center; background: rgba(255,255,255,.9); border: 1px solid rgba(200,182,255,.65); border-radius: 2rem; box-shadow: 0 1.5rem 4rem rgba(94,84,142,.14); }
        .brand { color: #5e548e; font-weight: 800; margin-bottom: 1.5rem; }
        h1 { margin: 0; font-size: 1.75rem; letter-spacing: -.04em; color: #342963; }
        p { color: #70688b; line-height: 1.6; font-size: .92rem; }
        form { margin-top: 1.5rem; text-align: left; }
        label { display: block; margin: 1rem 0 .35rem; color: #5e548e; font-size: .8rem; font-weight: 700; }
        input { width: 100%; min-height: 2.8rem; padding: .7rem .85rem; border: 1px solid #c8b6ff; border-radius: .75rem; color: #332a5e; font: inherit; }
        button, a { display: inline-flex; justify-content: center; align-items: center; width: 100%; min-height: 2.9rem; margin-top: 1.35rem; padding: .7rem 1.25rem; border: 0; border-radius: .85rem; color: white; background: #5e548e; font: inherit; font-weight: 750; text-decoration: none; cursor: pointer; }
        .error { margin-top: 1rem; padding: .75rem; color: #9d3652; background: #fff0f3; border-radius: .75rem; font-size: .85rem; }
        .success { color: #18865b; }
    </style>
</head>
<body>
    <main>
        <section class="card" aria-labelledby="reset-title">
            <div class="brand">✦ Aura Board</div>
            @if (isSuccess)
            {
                <h1 id="reset-title">@title</h1>
                <p class="success">You can now sign in with your new password.</p>
                <a href="/">Sign in to Aura Board</a>
            }
            else
            {
                <h1 id="reset-title">Set a new password</h1>
                <p>Choose a new password for your Aura Board account.</p>
                @if (isError)
                {
                    <div class="error">@title Request a new password-reset link from the sign-in screen.</div>
                }
                <form method="post" action="/api/auth/reset-password">
                    <input type="hidden" name="Email" value="@email" />
                    <input type="hidden" name="Token" value="@token" />
                    <label for="password">New password</label>
                    <input id="password" name="Password" type="password" minlength="8" maxlength="128" autocomplete="new-password" required autofocus />
                    <button type="submit">Update password</button>
                </form>
            }
        </section>
    </main>
</body>
</html>
